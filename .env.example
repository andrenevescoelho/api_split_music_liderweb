APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

BASE_URL=http://localhost:8000
STORAGE_DIR=/app/storage
TEMP_DIR=/app/storage/tmp
OUTPUT_DIR=/app/storage/jobs

MAX_UPLOAD_MB=100
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

YTDLP_ENABLED=true
YTDLP_COOKIEFILE=
# Dica: se vazio, a API tenta usar secrets/cookies.txt automaticamente
YTDLP_COOKIES_FROM_BROWSER=
API_KEY=
DEMUCS_MODEL=htdemucs
